# ═══════════════════════════════════════════════════════════════
#  TRACE-X — Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ── Google Cloud ──────────────────────────────────────────────
GCP_PROJECT_ID=tracex-hackathon
GCP_REGION=us-central1
# Path to your service account JSON key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Vertex AI / Gemini ────────────────────────────────────────
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash-001
GEMINI_TEMPERATURE=0.2

# ── Arize MCP (optional — demo mock used if not set) ─────────
ARIZE_API_KEY=
ARIZE_SPACE_KEY=
ARIZE_MCP_SERVER_URL=http://localhost:8765

# ── Firestore ─────────────────────────────────────────────────
FIRESTORE_DATABASE=(default)
FIRESTORE_TRACES_COLLECTION=traces
FIRESTORE_AGENTS_COLLECTION=agents
FIRESTORE_DIAGNOSES_COLLECTION=diagnoses
FIRESTORE_REPAIRS_COLLECTION=repairs

# ── BigQuery ──────────────────────────────────────────────────
BIGQUERY_DATASET=tracex_analytics
BIGQUERY_TRACES_TABLE=traces

# ── Pub/Sub ───────────────────────────────────────────────────
PUBSUB_TRACES_TOPIC=tracex-traces
PUBSUB_EVENTS_TOPIC=tracex-events
PUBSUB_SUBSCRIPTION_TRACES=tracex-traces-sub

# ── Auth ──────────────────────────────────────────────────────
# Comma-separated list of valid API keys
API_KEYS=demo-api-key-tracex-hackathon
API_SECRET_KEY=change-me-in-production-min-32-chars

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Frontend (.env.local) ─────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
# NEXT_PUBLIC_API_KEY=demo-api-key-tracex-hackathon
